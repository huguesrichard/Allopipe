profiles {
    conda {
        includeConfig './conf/conda.config'
    }
}


params {
    // General parameters
    mode = "pair"
    output_dir = "output"                   // default in python mode 
    process.debug = true                    // show prints (not real time: after it's ran)
    

    // VEP parameters
    skip_vep_annotation = false
    sif_dir = '$SCRATCH'                    // consider run locally outside of slurm


    // Allo-count parameters
    donor           = null
    recipient       = null
    multi_vcf       = null
    pairs           = null
    run_name        = null
    orientation     = null
    imputation      = null
    allo_count_opts = ""


    // Allo-affinity parameters
    run_name           = null
	ensembl_path       = null
	hla_typing         = null
	allo_affinity_opts = ""
}


singularity {
    enabled    = false                      // check for slurm
    autoMounts = true
}


docker {
    enabled    = true
    runOptions = '-v $HOME/.vep:/cache'
}