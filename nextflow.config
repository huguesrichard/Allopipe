profiles {
    conda {
        includeConfig './conf/conda.config'
    }
}


params {
    skip_vep_annotation = false
    
    sif_dir = '$SCRATCH'                    // consider run locally outside of slurm

    process.debug = true                    // show prints (not real time: after it's ran)

    // Allo-count parameters
    donor         = null
    recipient     = null
    run_name      = null
    orientation   = null
    imputation    = null
    optional_args = ""

    // Allo-affinity parameters
    
}


singularity {
    enabled    = true
    autoMounts = true
}